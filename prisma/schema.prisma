// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  ADMIN
  CLIENT
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum ImageType {
  SAMPLE
  GENERATED
}

enum ImageStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum JobType {
  SAMPLE_BATCH
  CLIENT_GENERATION
}

//////////////////////
// MODELS
//////////////////////

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         UserRole @default(CLIENT)

  images GeneratedImage[]
  jobs   GenerationJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String         @id @default(uuid())
  name        String
  description String?
  status      TemplateStatus @default(DRAFT)

  provider  String
  modelName String

  basePrompt     String
  negativePrompt String?

  width  Int
  height Int

  sampleCount Int @default(4)

  previewUrl String?
  tags       String[]

  images GeneratedImage[]
  jobs   GenerationJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedImage {
  id     String      @id @default(uuid())
  type   ImageType
  status ImageStatus @default(ACTIVE)

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  sourceSampleId String?
  sourceSample   GeneratedImage?  @relation("SampleToGenerated", fields: [sourceSampleId], references: [id])
  generated      GeneratedImage[] @relation("SampleToGenerated")

  jobsAsSample GenerationJob[]

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  subjectPrompt  String?
  fullPromptUsed String

  provider  String
  modelName String

  seed String?

  width  Int
  height Int

  gcsPath       String
  thumbnailPath String?

  createdAt DateTime @default(now())
}

model GenerationJob {
  id String @id @default(uuid())

  jobType JobType
  status  JobStatus @default(QUEUED)

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  sampleId String?
  sample   GeneratedImage? @relation(fields: [sampleId], references: [id])

  requestedById String?
  requestedBy   User?   @relation(fields: [requestedById], references: [id])

  subjectPrompt String?
  payloadJson   Json
  resultImageId String?
  error         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
